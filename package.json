{
  "name": "musiker15-website",
  "version": "1.0.0",
  "private": true,
  "description": "Persönliche Website von Moritz Kohm (Musiker15) — Tutorials & Guides",
  "license": "SEE LICENSE IN LICENSE.md",
  "author": "Moritz Kohm",
  "repository": {
    "type": "git",
    "url": "https://github.com/Musiker15/Website.git"
  },
  "type": "module",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@11.1.2",
  "scripts": {
    "dev": "next dev --turbopack -p 3000",
    "build": "next build --turbopack",
    "start": "next start -p 3000",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "type-check": "tsc --noEmit",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,mdx,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,mdx,css}\"",
    "validate:content": "tsx scripts/validate-content.ts",
    "build:search": "tsx scripts/build-search-index.ts",
    "test": "vitest --passWithNoTests",
    "test:e2e": "playwright test",
    "prebuild": "pnpm run validate:content && pnpm run build:search"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.1.1",
    "@fontsource-variable/jetbrains-mono": "^5.1.2",
    "@radix-ui/react-dialog": "^1.1.16",
    "@radix-ui/react-dropdown-menu": "^2.1.17",
    "@radix-ui/react-navigation-menu": "^1.2.15",
    "@radix-ui/react-slot": "^1.2.5",
    "@radix-ui/react-tooltip": "^1.2.9",
    "clsx": "^2.1.1",
    "flexsearch": "^0.8.212",
    "geist": "^1.7.2",
    "gray-matter": "^4.0.3",
    "lucide-react": "^1.22.0",
    "next": "^16.2.7",
    "next-intl": "^4.13.0",
    "next-mdx-remote": "^6.0.0",
    "next-themes": "^0.4.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-pretty-code": "^0.14.4",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.0",
    "remark-toc": "^9.0.0",
    "shiki": "^4.3.1",
    "tailwind-merge": "^2.5.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4.0.0",
    "@tailwindcss/typography": "^0.5.20",
    "@types/mdx": "^2.0.14",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.0.2",
    "eslint": "^9.17.0",
    "postcss": "^8.4.49",
    "prettier": "^3.9.1",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.22.4",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.62.0",
    "vitest": "^4.1.8"
  }
}
